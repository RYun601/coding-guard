{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "edit|write",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${PLUGIN_ROOT}/hooks/scripts/check_bom.py\" pre",
          "timeout": 10
        }]
      },
      {
        "matcher": "edit|write",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${PLUGIN_ROOT}/hooks/scripts/check_secrets.py\"",
          "timeout": 10
        }]
      },
      {
        "matcher": "bash|powershell",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${PLUGIN_ROOT}/hooks/scripts/block_dangerous_cmd.py\"",
          "timeout": 10
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "edit|write",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${PLUGIN_ROOT}/hooks/scripts/check_bom.py\" post",
          "timeout": 10
        }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${PLUGIN_ROOT}/hooks/scripts/session_context.py\"",
          "timeout": 15
        }]
      }
    ]
  }
}
