{
  "description": "编码安全守护 — BOM 检测与拦截、危险写入命令拦截、硬编码凭据扫描、项目技术栈感知",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_bom.py\" pre",
          "timeout": 10,
          "statusMessage": "coding-guard: 检查 BOM 头..."
        }]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_secrets.py\"",
          "timeout": 10,
          "statusMessage": "coding-guard: 检查硬编码凭据..."
        }]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block_dangerous_cmd.py\"",
          "timeout": 10,
          "statusMessage": "coding-guard: 检查命令安全性..."
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_bom.py\" post",
          "timeout": 10,
          "statusMessage": "coding-guard: 验证写入后编码..."
        }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [{
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session_context.py\"",
          "timeout": 15,
          "statusMessage": "coding-guard: 检测项目技术栈..."
        }]
      }
    ]
  }
}
